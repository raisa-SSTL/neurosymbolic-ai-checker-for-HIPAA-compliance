@prefix hipaa: <http://hipaa-checker.org/ontology#> .

<http://hipaa-checker.org/ontology#Medplum—medplum_GitHub> a hipaa:ExternalService ;
    hipaa:belongs_To_System <http://hipaa-checker.org/ontology#Medplum—medplum> ;
    hipaa:component_Name "GitHub" ;
    hipaa:component_Type "External" ;
    hipaa:handles_PHI "No" ;
    hipaa:has_AuditLog "Yes" ;
    hipaa:has_BAC_Contract "No" ;
    hipaa:has_Encryption "Yes" ;
    hipaa:is_External "Yes" ;
    hipaa:sends_Data_To <http://hipaa-checker.org/ontology#Medplum—medplum_Medplum> .

